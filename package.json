{
  "name": "avtoikonom-e2e",
  "version": "1.0.0",
  "description": "End-to-end automated testing solution for the Avtoikonom admin platform (Partners lifecycle) built with Cypress + TypeScript.",
  "private": true,
  "scripts": {
    "cy:open": "cypress open --e2e",
    "cy:run": "cypress run",
    "cy:run:chrome": "cypress run --browser chrome",
    "cy:run:firefox": "cypress run --browser firefox",
    "test": "cypress run",
    "test:chrome": "cypress run --browser chrome",
    "test:firefox": "cypress run --browser firefox",
    "test:partners": "cypress run --spec \"cypress/e2e/partners/**/*.cy.ts\"",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "report:merge": "mochawesome-merge \"cypress/reports/mochawesome/*.json\" > cypress/reports/mochawesome/index.json",
    "report:generate": "marge cypress/reports/mochawesome/index.json --reportDir cypress/reports/html --inline",
    "report": "npm run report:merge && npm run report:generate",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cypress",
    "typescript",
    "e2e",
    "automation",
    "qa"
  ],
  "license": "MIT",
  "devDependencies": {
    "@faker-js/faker": "^9.3.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "cypress": "^13.17.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-cypress": "^3.5.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
